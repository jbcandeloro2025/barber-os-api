# --- DATABASE ---
# Conexão principal (Supabase/PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/postgres?pgbouncer=true"
# Conexão direta para migrações
DIRECT_URL="postgresql://user:password@host:port/postgres"

# --- AUTH ---
JWT_SECRET="sua-chave-secreta-aqui"

# --- STRIPE ---
STRIPE_PUBLIC_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- WHATSAPP (EVOLUTION API) ---
WHATSAPP_API_URL="https://sua-instancia-evo.com"
WHATSAPP_GLOBAL_API_KEY="seu-token-global"

# --- APP CONFIG ---
PORT=3333
NODE_ENV=production
